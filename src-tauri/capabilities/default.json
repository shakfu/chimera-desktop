{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "webviews": ["*"],
  "local": true,
  "remote": {
    "urls": ["http://localhost:1420/*", "tauri://localhost/*"]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/chimera",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "binaries/chimera",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://127.0.0.1:*" }]
    }
  ]
}
